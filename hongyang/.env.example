HYDRADB_TENANT_ID=hongyang

# === Photon / iMessage Kit (Messaging Delivery) ===
# Set to a phone number or email to receive VN link via iMessage.
# Requires macOS + Full Disk Access. Leave empty to skip.
PHOTON_RECIPIENT=+14251234567

# === Server ===
PORT=3000
